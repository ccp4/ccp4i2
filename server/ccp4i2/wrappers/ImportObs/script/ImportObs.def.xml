<?xml version='1.0' encoding='ASCII'?>
<ccp4:ccp4i2 xmlns:ccp4="http://www.ccp4.ac.uk/ccp4ns">
  <ccp4i2_header>
    <function>DEF</function>
    <pluginName>ImportObs</pluginName>
  </ccp4i2_header>
  <ccp4i2_body id="ImportObs">
    <container id="inputData">
      <content id="HKLIN">
        <className>CMtzDataFile</className>
        <qualifiers>
          <mustExist>True</mustExist>
          <allowUndefined>False</allowUndefined>
          <fromPreviousJob>False</fromPreviousJob>
          <guiLabel>MTZ file</guiLabel>
          <toolTip>A full MTZ file from which to extract observed reflections</toolTip>
        </qualifiers>
      </content>
    </container>
    <container id="controlParameters">
      <content id="COLUMNS">
        <className>CString</className>
        <qualifiers>
          <allowUndefined>True</allowUndefined>
          <guiLabel>Columns</guiLabel>
          <toolTip>Comma-separated source column labels. Leave blank to auto-detect; required only when the file has more than one observation column group.</toolTip>
        </qualifiers>
      </content>
    </container>
    <container id="outputData">
      <content id="OBSOUT">
        <className>CObsDataFile</className>
        <qualifiers>
          <saveToDb>True</saveToDb>
        </qualifiers>
      </content>
    </container>
  </ccp4i2_body>
</ccp4:ccp4i2>
