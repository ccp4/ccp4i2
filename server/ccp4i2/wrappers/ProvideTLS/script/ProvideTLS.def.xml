<?xml version='1.0' encoding='ASCII'?>
<ccp4:ccp4i2 xmlns:ccp4="http://www.ccp4.ac.uk/ccp4ns">
    <ccp4i2_header>
        <function>DEF</function>
        <pluginName>ProvideTLS</pluginName>
    </ccp4i2_header>
    <ccp4i2_body id="ProvideTLS">
        <container id="controlParameters">
            <content id="TLSTEXT">
                <className>CString</className>
                <qualifiers>
                    <guiMode>multiLine</guiMode>
                    <default>
TLS From REFMAC
RANGE  'A   0.' 'A 999.' ALL
                    </default>
                </qualifiers>
            </content>
            <content id="TLSGROUPS">
                <className>CTLSRangeList</className>
                <qualifiers>
                    <listMinLength>0</listMinLength>
                </qualifiers>
            </content>
        </container>
        <container id="inputData">
            <content id="TLSIN">
                <className>CTLSDataFile</className>
                <qualifiers>
                    <mustExist>True</mustExist>
                    <allowUndefined>True</allowUndefined>
                    <fromPreviousJob>False</fromPreviousJob>
                </qualifiers>
            </content>
            <content id="XYZIN">
                <className>CPdbDataFile</className>
                <qualifiers>
                    <mustExist>True</mustExist>
                    <allowUndefined>True</allowUndefined>
                    <fromPreviousJob>False</fromPreviousJob>
                </qualifiers>
            </content>
        </container>
        <container id="guiParameters">
            <content id="EDIT_MODE">
                <className>CString</className>
                <qualifiers>
                    <onlyEnumerators>True</onlyEnumerators>
                    <enumerators>table,text</enumerators>
                    <menuText>Structured table,Free text</menuText>
                    <default>table</default>
                </qualifiers>
            </content>
        </container>
        <container id="outputData">
            <content id="TLSFILE">
                <className>CTLSDataFile</className>
                <qualifiers>
                    <baseName>
                        <allowedCharacters>*?</allowedCharacters>
                    </baseName>
                    <relPath>
                        <allowedCharacters>*?</allowedCharacters>
                    </relPath>
                </qualifiers>
            </content>
        </container>
    </ccp4i2_body>
</ccp4:ccp4i2>
