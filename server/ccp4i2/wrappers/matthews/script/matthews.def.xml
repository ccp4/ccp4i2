<?xml version='1.0' encoding='ASCII'?>
<ccp4:ccp4i2 xmlns:ccp4="http://www.ccp4.ac.uk/ccp4ns">
  <ccp4i2_header>
    <function>DEF</function>
    <pluginName>matthews</pluginName>
  </ccp4i2_header>
  <ccp4i2_body id="Cell content analysis">
    <container id="inputData">
      <content id="HKLIN">
        <className>CMtzDataFile</className>
        <qualifiers>
          <mustExist>True</mustExist>
          <allowUndefined>False</allowUndefined>
          <fromPreviousJob>True</fromPreviousJob>
        </qualifiers>
      </content>
      <content id="ASUIN">
        <className>CAsuDataFile</className>
        <qualifiers>
          <mustExist>True</mustExist>
          <allowUndefined>True</allowUndefined>
          <fromPreviousJob>True</fromPreviousJob>
          <selectionMode>2</selectionMode>
        </qualifiers>
      </content>
      <content id="MOLWT">
        <className>CFloat</className>
        <qualifiers>
          <allowUndefined>True</allowUndefined>
          <min>0.0</min>
        </qualifiers>
      </content>
      <content id="NRES">
        <className>CInt</className>
        <qualifiers>
          <allowUndefined>True</allowUndefined>
          <min>0</min>
        </qualifiers>
      </content>
      <content id="MODE">
        <className>CString</className>
        <qualifiers>
          <onlyEnumerators>True</onlyEnumerators>
          <enumerators>asu_components,nres,molwt</enumerators>
          <default>asu_components</default>
        </qualifiers>
      </content>
    </container>
  </ccp4i2_body>
</ccp4:ccp4i2>
