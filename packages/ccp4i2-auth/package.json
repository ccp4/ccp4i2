{
  "name": "@ccp4/ccp4i2-auth",
  "version": "0.0.0-dev",
  "description": "Shared auth + api-fetch contract for CCP4i2 and consumers (CCP4i2 Compounds, third-party integrators)",
  "license": "LGPL-3.0-or-later",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "watch": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf lib",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "jsdom": "^24.1.3",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
